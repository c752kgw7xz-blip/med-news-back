{
  "appId": "fr.mednews.app",
  "appName": "MedNews",
  "webDir": "www",
  "server": {
    "androidScheme": "https"
  },
  "plugins": {
    "PushNotifications": {
      "presentationOptions": ["badge", "sound", "alert"]
    },
    "LocalNotifications": {
      "smallIcon": "ic_stat_icon_config_sample",
      "iconColor": "#1f9478"
    }
  },
  "ios": {
    "contentInset": "automatic",
    "backgroundColor": "#0f1117",
    "limitsNavigationsToAppBoundDomains": true
  },
  "android": {
    "backgroundColor": "#0f1117"
  }
}
