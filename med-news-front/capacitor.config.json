{
  "appId": "fr.mednews.app",
  "appName": "MedNews",
  "webDir": "www",
  "server": {
    "url": "https://med-news.fr",
    "cleartext": false
  },
  "plugins": {
    "PushNotifications": {
      "presentationOptions": ["badge", "sound", "alert"]
    },
    "LocalNotifications": {
      "smallIcon": "ic_stat_icon_config_sample",
      "iconColor": "#1f9478"
    }
  },
  "ios": {
    "contentInset": "automatic",
    "backgroundColor": "#F5F0E8"
  },
  "android": {
    "backgroundColor": "#F5F0E8"
  }
}
