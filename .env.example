# ============================================================
# med-news-back — variables d'environnement
# Copier ce fichier en .env et remplir les valeurs
# NE JAMAIS committer le fichier .env
# ============================================================

# --- Base de données PostgreSQL ---
DATABASE_URL=postgresql://user:password@localhost:5432/mednews

# --- Sécurité JWT ---
JWT_SECRET=change-moi-en-prod-32-chars-min
REFRESH_TOKEN_PEPPER=change-moi-aussi-32-chars-min
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_SECONDS=2592000

# --- Chiffrement email (Fernet AES-128) ---
# Générer avec : python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
EMAIL_ENCRYPTION_KEY=

# --- CORS (origines autorisées, séparées par des virgules) ---
# Ex: https://app.mednews.fr,https://admin.mednews.fr
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# --- Secrets admin ---
ADMIN_SECRET=mon-secret-admin
DB_INIT_SECRET=mon-secret-init
MIGRATE_SECRET=mon-secret-migrate

# --- API Légifrance (PISTE) ---
PISTE_CLIENT_ID=
PISTE_CLIENT_SECRET=
PISTE_ENV=sandbox   # sandbox | prod

# --- Anthropic (analyse LLM) ---
ANTHROPIC_API_KEY=sk-ant-...

# --- Email (choisir l'un ou l'autre) ---
# Option 1 : SendGrid
SENDGRID_API_KEY=SG.xxxxx
# Option 2 : SMTP
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=ton@email.fr
# SMTP_PASSWORD=mot_de_passe
# SMTP_USE_TLS=true

MAIL_FROM=newsletter@mednews.fr
MAIL_FROM_NAME=MedNews

# --- Scheduler mensuel ---
# Mettre true pour activer l'automatisation
SCHEDULER_ENABLED=false
SCHEDULER_COLLECT_DAY=1    # Jour du mois : collecte + LLM
SCHEDULER_COLLECT_HOUR=6   # Heure UTC
SCHEDULER_SEND_DAY=7       # Jour du mois : envoi newsletter
SCHEDULER_SEND_HOUR=8      # Heure UTC

# --- URL publique du service (utilisée dans les emails de vérification) ---
# Ex: https://mon-app.onrender.com
BASE_URL=http://localhost:8000

# --- Inscription médecins ---
ALLOW_SIGNUP=false
